  },
  "engines": {
    "opencode": ">=1.4.6"
  },
  "dependencies": {
    "@opentui/core": "0.1.99",
    "@opentui/solid": "0.1.99"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.4.7",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
